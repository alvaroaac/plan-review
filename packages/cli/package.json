{
  "name": "plan-review",
  "version": "1.1.2",
  "description": "Interactive CLI for reviewing AI-generated markdown plans",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "plan-review": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "examples"
  ],
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": ""
  },
  "keywords": [
    "markdown",
    "plan",
    "review",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alvaroaac/plan-review.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/alvaroaac/plan-review/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/alvaroaac/plan-review/issues"
  },
  "dependencies": {
    "@plan-review/core": "*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
